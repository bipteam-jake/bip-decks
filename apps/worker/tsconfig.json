{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "../..",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../apps/web/*"]
    }
  },
  "include": ["src/**/*.ts", "../../apps/web/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

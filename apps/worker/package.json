{
  "name": "@bip/worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ worker process. Idle in Phase 1/2, dispatch in Phase 3.",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json --env-file=../../.env.local src/index.ts",
    "start": "node --enable-source-maps -r tsconfig-paths/register dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bip/ai-gateway": "*",
    "@bip/db": "*",
    "@bip/shared": "*",
    "bullmq": "^5.13.2",
    "ioredis": "^5.4.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}

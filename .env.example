# BIP Deck Platform — environment variables.
# Copy to .env.local and fill in the secrets. .env.local is gitignored.
# Per docs/bip-deck-platform-deployment.md §4.

# --- Database ---
DATABASE_URL=postgresql://bip:dev@postgres:5432/bip_deck_platform
# Hybrid dev (Next.js + worker on host, data services in Docker):
# DATABASE_URL=postgresql://bip:dev@localhost:5432/bip_deck_platform

# --- Redis ---
REDIS_URL=redis://redis:6379
# Hybrid dev:
# REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible; MinIO locally, R2 / BIP S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bip-deck-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Hybrid dev:
# S3_ENDPOINT=http://localhost:9000

# --- Deck repos (mounted volume in containers) ---
DECK_REPOS_PATH=/var/bip/deck-repos
# Hybrid dev:
# DECK_REPOS_PATH=./deck-repos

# --- Auth ---
# 32-byte random hex. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32
# argon2id parameters use sensible defaults; override only if needed.

# --- Email ---
EMAIL_PROVIDER=resend           # or postmark
EMAIL_API_KEY=replace-me
EMAIL_FROM=decks@bip.com

# --- AI ---
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# --- Application ---
APP_BASE_URL=http://localhost:3000
# Production: https://decks.bip.internal (or whatever the dev team assigns)

# --- Misc ---
LOG_LEVEL=info
NODE_ENV=development
